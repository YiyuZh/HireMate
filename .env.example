# HireMate production .env
# 1. Copy to .env before docker compose up
# 2. Replace every value wrapped in <...>
# 3. If you will reuse the current live MySQL data volume, do not invent new database
#    passwords here. Reuse the same values currently used by /opt/hiremate.

# Database
HIREMATE_MYSQL_DATABASE=hiremate
HIREMATE_MYSQL_USER=hiremate
HIREMATE_MYSQL_PASSWORD=<HIREMATE_MYSQL_APP_PASSWORD>
HIREMATE_MYSQL_ROOT_PASSWORD=<HIREMATE_MYSQL_ROOT_PASSWORD>

# AI settings
# HireMate supports DeepSeek in two ways:
# 1) In-app AI reviewer setting: choose provider=deepseek and use DEEPSEEK_API_KEY
# 2) Simple env mode below: point the OpenAI-compatible fields to DeepSeek
#    OPENAI_API_KEY=<YOUR_DEEPSEEK_API_KEY>
#    OPENAI_BASE_URL=https://api.deepseek.com/v1
#    MODEL_NAME=deepseek-chat
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=gpt-4o-mini
DEEPSEEK_API_KEY=

# Shared gateway network
SHARED_CADDY_NETWORK=shared_gateway

# Build mirrors for China mainland deployment.
# These are used at image build time for apt / pip acceleration.
APT_MIRROR_HOST=mirrors.tuna.tsinghua.edu.cn
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Public gateway domains used by hiremate-caddy.
# These values are required for Caddy to start successfully.
# Do not keep angle-bracket placeholders in the live .env file.
CADDY_ACME_EMAIL=<YOUR_ACME_EMAIL>
PRIMARY_DOMAIN=<YOUR_PORTAL_DOMAIN>
HIREMATE_DOMAIN=<YOUR_HIREMATE_DOMAIN>
INTERVIEW_DOMAIN=<YOUR_INTERVIEW_DOMAIN>
ADMIN_DOMAIN=<YOUR_ADMIN_DOMAIN>

# Optional. Set these only when the old live volume names do not match the defaults.
# Leave them commented or blank if the live volume names are already:
# hiremate_hiremate_data
# hiremate_hiremate_mysql_data
# hiremate_caddy_data
# hiremate_caddy_config
# HIREMATE_DATA_VOLUME_NAME=
# HIREMATE_MYSQL_VOLUME_NAME=
# HIREMATE_CADDY_DATA_VOLUME_NAME=
# HIREMATE_CADDY_CONFIG_VOLUME_NAME=
