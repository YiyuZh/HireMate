{
    email {$CADDY_ACME_EMAIL}
    # Prefer RSA leaf certificates on this gateway because the current
    # Windows/Schannel public path resets during ECDSA certificate handshakes.
    key_type rsa2048
    servers {
        protocols h1 h2 h3
    }
}

(common_site) {
    encode zstd gzip

    header {
        -Server
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
    }
}

(admin_auth_access_log) {
    log {
        output file /var/log/caddy/access.log {
            roll_size 10MiB
            roll_keep 5
            roll_keep_for 168h
        }
        format json
    }
}

(hiremate_cache_policy) {
    @hiremate_assets path /assets/* /static/* /favicon.ico /favicon.png
    header @hiremate_assets Cache-Control "public, max-age=31536000, immutable"

    @hiremate_dynamic {
        not path /assets/* /static/* /api/* /favicon.ico /favicon.png /robots.txt
    }
    header @hiremate_dynamic Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    header @hiremate_dynamic Pragma "no-cache"
    header @hiremate_dynamic Expires "0"
}

(ai_backend_routes) {
    @backend path /api/* /uploads/* /client/* /backoffice/*
    handle @backend {
        reverse_proxy ai-interview-app:8001
    }
}

(portal_api_upstream) {
    reverse_proxy portal-messages-api:8000 {
        # A set operation overwrites any client-supplied value. Do not also
        # configure a delete operation for this field: Caddy applies deletes
        # after sets, which would remove the trusted value before proxying.
        header_up X-Portal-Gateway-Token {$PORTAL_GATEWAY_TOKEN}
    }
}

(portal_messages_api_routes) {
    @portal_messages_admin path /api/admin/messages* /api/admin/assistant* /api/admin/knowledge*
    handle @portal_messages_admin {
        basic_auth {
            autsky6666@gmail.com $2b$12$bM/k/LvfDRXIKywrhrLmh.wEa8v8N15cluiTcQStDUjMtBNReZbYm
        }
        import portal_api_upstream
    }

    @portal_messages_public path /api/messages* /api/assistant* /api/health
    handle @portal_messages_public {
        import portal_api_upstream
    }
}

{$PRIMARY_DOMAIN} {
    import common_site
    import admin_auth_access_log
    import portal_messages_api_routes

    handle {
        reverse_proxy portal-nginx:80
    }
}

www.zenithy.art {
    import common_site
    redir https://zenithy.art{uri} permanent
}

blog.zenithy.art {
    import common_site
    import admin_auth_access_log
    import portal_messages_api_routes

    @legacy_blog_post path /post.html
    redir @legacy_blog_post / permanent

    @blog_admin path /admin /admin/* 
    basic_auth @blog_admin {
        autsky6666@gmail.com $2b$12$bM/k/LvfDRXIKywrhrLmh.wEa8v8N15cluiTcQStDUjMtBNReZbYm
    }
    @blog_assets path /assets/* /favicon* /manifest.json
    handle @blog_assets {
        reverse_proxy portal-nginx:80
    }
    handle @blog_admin {
        rewrite * /blog{path}
        reverse_proxy portal-nginx:80
    }
    handle {
        rewrite * /blog{path}
        reverse_proxy portal-nginx:80
    }
}

{$HIREMATE_DOMAIN} {
    import common_site
    import hiremate_cache_policy

    @hiremate_api path /api/*
    handle @hiremate_api {
        reverse_proxy hiremate-api:8000
    }

    handle {
        reverse_proxy hiremate-web:80
    }
}

headhunt.zenithy.art {
    import common_site
    import admin_auth_access_log

    @headhunt_public path /health /discord/interactions /feishu/events /feishu/card-actions
    @headhunt_internal path /ready /version /discord/commands/register /tasks* /approvals* /threads* /runs* /council* /docs* /redoc* /openapi.json
    @headhunt_missing_admin {
        path /ready /version /discord/commands/register /tasks* /approvals* /threads* /runs* /council* /docs* /redoc* /openapi.json
        not header X-Internal-Admin-Key *
    }

    handle @headhunt_missing_admin {
        respond "internal admin key required" 403
    }

    handle @headhunt_public {
        reverse_proxy lietou-api:8000
    }

    handle @headhunt_internal {
        reverse_proxy lietou-api:8000
    }

    handle {
        respond "not found" 404
    }
}

