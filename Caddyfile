{
    email {$CADDY_ACME_EMAIL}
    # Prefer RSA leaf certificates on this gateway because the current
    # Windows/Schannel public path resets during ECDSA certificate handshakes.
    key_type rsa2048
    servers {
        protocols h1 h2 h3
    }
}

(common_site) {
    encode zstd gzip

    header {
        -Server
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
    }
}

(hiremate_cache_policy) {
    @hiremate_static path /static/*
    header @hiremate_static Cache-Control "public, max-age=31536000, immutable"

    @hiremate_dynamic {
        not path /static/* /_stcore/* /favicon.ico /favicon.png /robots.txt
    }
    header @hiremate_dynamic Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    header @hiremate_dynamic Pragma "no-cache"
    header @hiremate_dynamic Expires "0"
}

(ai_backend_routes) {
    @backend path /api/* /uploads/* /client/* /backoffice/*
    handle @backend {
        reverse_proxy ai-interview-app:8001
    }
}

(portal_messages_api_routes) {
    @portal_messages_api path /api/messages* /api/admin/messages*
    handle @portal_messages_api {
        reverse_proxy portal-messages-api:8000
    }
}

{$PRIMARY_DOMAIN} {
    import common_site
    import portal_messages_api_routes

    handle {
        reverse_proxy portal-nginx:80
    }
}

blog.zenithy.art {
    import common_site
    import portal_messages_api_routes

    @blog_admin path /admin /admin/* 
    basicauth @blog_admin {
        autsky6666@gmail.com $2b$12$bM/k/LvfDRXIKywrhrLmh.wEa8v8N15cluiTcQStDUjMtBNReZbYm
    }
    @blog_assets path /assets/* /favicon* /manifest.json
    handle @blog_assets {
        reverse_proxy portal-nginx:80
    }
    handle @blog_admin {
        rewrite * /blog{path}
        reverse_proxy portal-nginx:80
    }
    handle {
        rewrite * /blog{path}
        reverse_proxy portal-nginx:80
    }
}

{$HIREMATE_DOMAIN} {
    import common_site
    import hiremate_cache_policy
    reverse_proxy hiremate:8501
}

{$INTERVIEW_DOMAIN} {
    import common_site
    import ai_backend_routes

    handle {
        reverse_proxy ai-interview-frontend:80
    }
}

{$ADMIN_DOMAIN} {
    import common_site
    import ai_backend_routes

    handle {
        reverse_proxy ai-interview-admin:80
    }
}
